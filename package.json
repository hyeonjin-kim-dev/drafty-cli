{
    "name": "drafty-cli",
    "version": "0.1.0",
    "description": "Cross-platform CLI note capture with Supabase auth",
    "private": true,
    "type": "module",
    "bin": {
        "drafty": "dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "cli": "node dist/cli.js",
        "dev": "tsx src/cli.ts",
        "dev:watch": "tsx watch src/cli.ts",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "check": "npm run typecheck && npm run build",
        "link:global": "npm link",
        "db:push": "npx supabase db push",
        "db:types": "node scripts/generate-db-types.mjs"
    },
    "dependencies": {
        "@inquirer/select": "^5.1.0",
        "@supabase/supabase-js": "^2.57.4",
        "commander": "^14.0.1",
        "dotenv": "^17.2.3"
    },
    "devDependencies": {
        "@types/node": "^24.7.2",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3"
    }
}
